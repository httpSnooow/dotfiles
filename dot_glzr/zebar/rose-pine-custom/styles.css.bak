@import "https://www.nerdfonts.com/assets/css/webfont.css";

/* =============================================
   Neutral Palette â€” estilo Rose Pine em P&B
   ============================================= */
:root {
  --base:         #0d0d0d;
  --surface:      #171717;
  --overlay:      #212121;
  --muted:        #3d3d3d;
  --subtle:       #777777;
  --text:         #dedede;
  --text-dim:     #aaaaaa;
  --border:       #2a2a2a;
  --border-hover: #404040;
  --accent:       #ffffff;
  --accent-soft:  #c8c8c8;
  --warn:         #b0b0b0;
}

/* =============================================
   Base
   ============================================= */
html, body, #root {
  height: 100%;
  overflow: hidden;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'JetBrainsMono Nerd Font', 'Cascadia Code NF', ui-monospace, monospace;
  font-size: 12px;
  color: var(--text);
  background: transparent;
}

#root {
  background: transparent;
}

/* =============================================
   Layout principal â€” 3 colunas
   ============================================= */
.app {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  align-items: center;
  height: 100%;
  padding: 0 12px;
}

.left {
  display: flex;
  align-items: center;
  gap: 6px;
}

.center {
  display: flex;
  align-items: center;
  justify-self: center;
}

.right {
  display: flex;
  align-items: center;
  justify-self: end;
  /* grupo de chips agrupados como no rose-pine */
  gap: 2px;
}

/* =============================================
   Logo
   ============================================= */
.logo {
  font-size: 15px;
  color: var(--accent-soft);
  margin-right: 8px;
  transition: color 0.2s ease;
}

.logo:hover {
  color: var(--accent);
}

/* =============================================
   Grupo de chips agrupados (estilo rose-pine)
   ============================================= */

/* Wrapper que agrupa chips com visual de "cÃ¡psula unificada" */
.group {
  display: flex;
  align-items: center;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-left: 6px;
  overflow: hidden;
  transition: border-color 0.15s ease;
}

.group:hover {
  border-color: var(--border-hover);
}

/* Chip dentro do grupo */
.group .chip {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 3px 10px;
  font-size: 11.5px;
  color: var(--subtle);
  white-space: nowrap;
  transition: background 0.15s ease, color 0.15s ease;
  border-right: 1px solid var(--border);
}

.group .chip:last-child {
  border-right: none;
}

.group .chip:hover {
  background: var(--overlay);
  color: var(--text-dim);
}

.group .chip i {
  font-size: 13px;
  color: var(--muted);
  margin-right: 0;
  transition: color 0.15s ease;
}

.group .chip:hover i {
  color: var(--accent-soft);
}

/* Chip standalone (sem grupo) */
.chip-solo {
  display: flex;
  align-items: center;
  gap: 5px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 3px 10px;
  margin-left: 6px;
  font-size: 11.5px;
  color: var(--subtle);
  white-space: nowrap;
  transition: all 0.15s ease;
}

.chip-solo:hover {
  background: var(--overlay);
  border-color: var(--border-hover);
  color: var(--text-dim);
}

.chip-solo i {
  font-size: 13px;
  color: var(--muted);
  margin-right: 0;
  transition: color 0.15s ease;
}

.chip-solo:hover i {
  color: var(--accent-soft);
}

/* =============================================
   Data/hora â€” cÃ¡psula central
   ============================================= */
.date-chip {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 3px 14px;
  font-size: 12px;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  transition: all 0.15s ease;
}

.date-chip:hover {
  border-color: var(--border-hover);
  color: var(--text);
}

.date-chip .sep {
  color: var(--muted);
  font-size: 10px;
}

/* =============================================
   CPU â€” aviso de uso alto
   ============================================= */
.high-usage {
  color: var(--warn);
  font-weight: 600;
}

/* =============================================
   Bateria â€” Ã­cone de carregando
   ============================================= */
.battery-wrap {
  position: relative;
}

.charging-icon {
  position: absolute;
  font-size: 7px;
  left: -6px;
  top: 3px;
  color: var(--accent-soft) !important;
}

/* =============================================
   Workspaces
   ============================================= */
.workspaces {
  display: flex;
  align-items: center;
  gap: 3px;
  margin-right: 8px;
}

.workspace {
  background: transparent;
  border: 1px solid transparent;
  border-radius: 6px;
  padding: 2px 9px;
  color: var(--muted);
  font-size: 11px;
  cursor: pointer;
  transition: all 0.15s ease;
}

.workspace.displayed {
  color: var(--subtle);
  border-color: var(--border);
  background: var(--surface);
}

.workspace.focused,
.workspace:hover {
  background: var(--overlay);
  color: var(--text);
  border-color: var(--border-hover);
}

/* =============================================
   Binding mode / tiling direction
   ============================================= */
.binding-mode,
.tiling-direction {
  background: var(--overlay);
  color: var(--accent-soft);
  border: 1px solid var(--border-hover);
  border-radius: 6px;
  padding: 2px 8px;
  font-size: 11px;
  margin-right: 6px;
  cursor: pointer;
}

