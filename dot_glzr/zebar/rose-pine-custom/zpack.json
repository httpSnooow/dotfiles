{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.3.1/resources/zpack-schema.json",
  "name": "rose-pine-custom",
  "version": "1.0.0",
  "widgets": [
    {
      "name": "rose-pine-custom-widget",
      "htmlPath": "./rose-pine-custom.html",
      "zOrder": "bottom_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "includeFiles": ["*.html", "*.css"],
      "presets": [
        {
          "name": "rose-pine-custom",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "40px",
          "monitorSelection": {
            "type": "all"
          }
        }
      ]
    }
  ]
}
